# ── Gemini API ──────────────────────────────────────────────────
# 前往 https://aistudio.google.com/app/apikey 获取
GEMINI_API_KEY=your_gemini_api_key_here

# 模型名称（可选，默认 gemini-flash-latest）
# 可选值参考：https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-flash-latest

# ── 抖音账号配置 ─────────────────────────────────────────────────
# 你的抖音主页 URL（在浏览器打开你的主页，复制地址栏链接）
DOUYIN_PROFILE_URL=https://www.douyin.com/user/你的UID

# 账号名称（用于界面展示和 AI 对话）
DOUYIN_ACCOUNT_NAME=我的抖音账号

# 账号背景信息（可选）
# 填写你的内容方向、已知规律等，AI 会基于此给出更精准的建议
# 例如：内容方向为美食探店，主要标签 #探店 #美食，粉丝5000，获赞20万
ACCOUNT_NOTES=

# ── web-access skill 路径（CDP 浏览器自动化）────────────────────
# 安装 web-access skill 后保持默认即可，无需修改
WEB_ACCESS_CHECK_DEPS=~/.claude/skills/web-access/scripts/check-deps.mjs
